api:
  embedding_api_key: YOUR_EMBEDDING_API_KEY
  embedding_base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
  embedding_model: text-embedding-v4
  llm_api_key: YOUR_LLM_API_KEY
  llm_base_url: https://apis.iflow.cn/v1
  llm_model: deepseek-v3
  model_director: deepseek-v3
  model_graphiti: deepseek-v3
  model_parser: deepseek-v3
  model_zep_extractor: deepseek-v3
business:
  chunk_max_length: 2000
  chunk_min_length: 100
  max_file_size_mb: 10
  neo4j_timeout: 30
  zep_timeout: 300
performance:
  batch_delay: 1.0
  batch_size: 2
  graphiti_llm_max_concurrency: 1
  graphiti_llm_min_interval: 0.5
  poll_interval: 5
  status_poll_interval: 3
